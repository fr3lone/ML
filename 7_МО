300x300 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","10. ГРАФИКИ ОБУЧЕНИЯ\n","--------------------------------------------------\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","================================================================================\n","ИТОГОВЫЕ РЕЗУЛЬТАТЫ\n","================================================================================\n","\n","ВАРИАНТ 1: Распознавание цифр 3 и 7\n","\n","1. ПЕРСЕПТРОН С ПОЛНОЙ РАЗМЕРНОСТЬЮ (784+1):\n","   - Лучшие параметры: learning_rate = 0.001, epochs = 50\n","   - Точность на обучающей выборке: 0.9915\n","   - Точность на тестовой выборке: 0.9795\n","   - Количество ошибок на тесте: 89 из 4331\n","\n","2. ПЕРСЕПТРОН С УМЕНЬШЕННОЙ РАЗМЕРНОСТЬЮ (196+1):\n","   - Лучшие параметры: learning_rate = 0.05, epochs = 50\n","   - Точность на обучающей выборке: 0.9864\n","   - Точность на тестовой выборке: 0.9605\n","   - Количество ошибок на тесте: 171 из 4331\n","\n","3. СРАВНЕНИЕ:\n","   - Разница в точности: 0.0189\n","   - Уменьшение размерности: 784 -> 196 (в 4 раза)\n","   - Потеря качества: 1.89%\n","\n","4. АНАЛИЗ ОШИБОК:\n","   - Основные причины ошибок:\n","     * Неразборчивое написание цифр\n","     * Похожие элементы в написании разных цифр\n","     * Низкая контрастность изображений\n","     * Смещение или наклон цифры\n","\n","\n","================================================================================\n","РАБОТА ВЫПОЛНЕНА УСПЕШНО!\n","================================================================================\n","\n","Результаты сохранены в файл 'results_pr7.txt'\n"]}],"source":["!mamba install Scikit-learn\n","!mamba install pandas\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from sklearn.datasets import fetch_openml\n","from sklearn.model_selection import train_test_split\n","import warnings\n","warnings.filterwarnings('ignore')\n","\n","plt.rcParams['figure.figsize'] = (15, 10)\n","\n","print(\"ПРАКТИЧЕСКАЯ РАБОТА №7: РАСПОЗНАВАНИЕ ЦИФР MNIST С ПОМОЩЬЮ ПЕРСЕПТРОНА\")\n","\n","print(\"\\n1. ЗАГРУЗКА ДАННЫХ MNIST\")\n","print(\"Загрузка данных MNIST (может занять некоторое время)...\")\n","\n","# Загрузка данных MNIST\n","mnist = fetch_openml('mnist_784', version=1, as_frame=False, parser='auto')\n","X, y = mnist.data / 255.0, mnist.target.astype(int)  # Нормализация [0, 1]\n","\n","print(f\"Размер данных: {X.shape}\")\n","print(f\"Количество классов: {len(np.unique(y))}\")\n","print(f\"Метки классов: {np.unique(y)}\")\n","print(f\"Диапазон значений пикселей: [{X.min():.2f}, {X.max():.2f}]\")\n","\n","# Вариант 1: цифры 3 и 7\n","VARIANT = 1\n","digit1, digit2 = 3, 7\n","\n","print(f\"\\n2. ВЫБОР ПОДМНОЖЕСТВА (ВАРИАНТ {VARIANT})\")\n","print(\"-\" * 50)\n","print(f\"Распознаваемые цифры: {digit1} и {digit2}\")\n","\n","# Фильтрация данных\n","mask = (y == digit1) | (y == digit2)\n","X_filtered = X[mask]\n","y_filtered = y[mask]\n","\n","# Преобразование меток в бинарные: digit1 -> 0, digit2 -> 1\n","y_binary = np.where(y_filtered == digit1, 0, 1)\n","\n","print(f\"Всего отобрано образцов: {len(X_filtered)}\")\n","print(f\"  Цифра {digit1} (класс 0): {sum(y_filtered == digit1)} образцов\")\n","print(f\"  Цифра {digit2} (класс 1): {sum(y_filtered == digit2)} образцов\")\n","\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X_filtered, y_binary, test_size=0.3, random_state=42, stratify=y_binary\n",")\n","\n","print(f\"\\n3. РАЗДЕЛЕНИЕ ДАННЫХ\")\n","print(f\"Обучающая выборка: {X_train.shape[0]} образцов\")\n","print(f\"  Класс 0 ({digit1}): {sum(y_train == 0)} образцов\")\n","print(f\"  Класс 1 ({digit2}): {sum(y_train == 1)} образцов\")\n","print(f\"Тестовая выборка: {X_test.shape[0]} образцов\")\n","print(f\"  Класс 0 ({digit1}): {sum(y_test == 0)} образцов\")\n","print(f\"  Класс 1 ({digit2}): {sum(y_test == 1)} образцов\")\n","\n","def plot_digit_samples(X, y, digit1, digit2, num_samples=10):\n","    fig, axes = plt.subplots(2, num_samples, figsize=(15, 4))\n","    fig.suptitle(f'Примеры цифр {digit1} и {digit2} из датасета MNIST', fontsize=16, fontweight='bold')\n","\n","    # Примеры цифры 1 (класс 0)\n","    indices_class0 = np.where(y == 0)[0][:num_samples]\n","    for i, idx in enumerate(indices_class0):\n","        axes[0, i].imshow(X[idx].reshape(28, 28), cmap='gray')\n","        axes[0, i].set_title(f'{digit1} (0)', fontsize=12)\n","        axes[0, i].axis('off')\n","\n","    # Примеры цифры 2 (класс 1)\n","    indices_class1 = np.where(y == 1)[0][:num_samples]\n","    for i, idx in enumerate(indices_class1):\n","        axes[1, i].imshow(X[idx].reshape(28, 28), cmap='gray')\n","        axes[1, i].set_title(f'{digit2} (1)', fontsize=12)\n","        axes[1, i].axis('off')\n","\n","    plt.tight_layout()\n","    plt.show()\n","\n","plot_digit_samples(X_train, y_train, digit1, digit2)\n","\n","class Perceptron:\n","\n","    def __init__(self, input_size, learning_rate=0.01, epochs=10, reduce_dim=False):\n","        self.learning_rate = learning_rate\n","        self.epochs = epochs\n","        self.reduce_dim = reduce_dim\n","        self.input_size = input_size\n","\n","        # Инициализация весов (включая bias)\n","        if reduce_dim:\n","            # Для уменьшенной размерности (196+1)\n","            self.weights = np.random.randn(197) * 0.01\n","        else:\n","            # Для полной размерности (784+1)\n","            self.weights = np.random.randn(785) * 0.01\n","\n","        self.loss_history = []\n","        self.accuracy_history = []\n","\n","    def _add_bias(self, X):\n","        return np.c_[X, np.ones(X.shape[0])]\n","\n","    def _reduce_dimension(self, X):\n","        if not self.reduce_dim:\n","            return X\n","\n","        n_samples = X.shape[0]\n","        X_reduced = np.zeros((n_samples, 196))\n","\n","        for i in range(n_samples):\n","            img = X[i].reshape(28, 28)\n","            reduced_img = np.zeros((14, 14))\n","            for r in range(14):\n","                for c in range(14):\n","                    reduced_img[r, c] = np.mean(img[2*r:2*r+2, 2*c:2*c+2])\n","            X_reduced[i] = reduced_img.flatten()\n","\n","        return X_reduced\n","\n","    def activation(self, x):\n","        return 1 if x >= 0 else 0\n","\n","    def predict(self, X):\n","        # Уменьшение размерности если нужно\n","        if self.reduce_dim:\n","            X = self._reduce_dimension(X)\n","\n","        # Добавление bias\n","        X_with_bias = self._add_bias(X)\n","\n","        # Вычисление выходов\n","        outputs = []\n","        for i in range(X_with_bias.shape[0]):\n","            linear_output = np.dot(self.weights, X_with_bias[i])\n","            outputs.append(self.activation(linear_output))\n","\n","        return np.array(outputs)\n","\n","    def fit(self, X, y, verbose=True):\n","        # Уменьшение размерности если нужно\n","        if self.reduce_dim:\n","            X = self._reduce_dimension(X)\n","            if verbose:\n","                print(f\"  Размерность уменьшена: 784 -> 196\")\n","\n","        # Добавление bias\n","        X_with_bias = self._add_bias(X)\n","\n","        if verbose:\n","            print(f\"  Начало обучения: lr={self.learning_rate}, epochs={self.epochs}\")\n","\n","        for epoch in range(self.epochs):\n","            errors = 0\n","            correct = 0\n","\n","            # Проход по всем образцам\n","            for i in range(X_with_bias.shape[0]):\n","                # Прямой проход\n","                linear_output = np.dot(self.weights, X_with_bias[i])\n","                y_pred = self.activation(linear_output)\n","\n","                # Обновление весов по правилу персептрона\n","                error = y[i] - y_pred\n","                if error != 0:\n","                    self.weights += self.learning_rate * error * X_with_bias[i]\n","                    errors += 1\n","                else:\n","                    correct += 1\n","\n","            # Вычисление точности на обучающей выборке\n","            accuracy = correct / X_with_bias.shape[0]\n","            self.accuracy_history.append(accuracy)\n","            self.loss_history.append(errors)\n","\n","            if verbose and (epoch % 5 == 0 or epoch == self.epochs - 1):\n","                print(f\"  Эпоха {epoch+1:3d}: ошибок={errors:4d}, точность={accuracy:.4f}\")\n","\n","        return self\n","\n","print(\"\\n4. ОБУЧЕНИЕ ПЕРСЕПТРОНА (784+1 ВХОД)\")\n","\n","# Сохраняем веса до обучения\n","perceptron_full_before = Perceptron(input_size=784, reduce_dim=False)\n","weights_before_full = perceptron_full_before.weights.copy()\n","\n","# Подбор параметров для максимального качества\n","best_accuracy_full = 0\n","best_params_full = {}\n","best_perceptron_full = None\n","\n","print(\"Подбор параметров обучения...\")\n","\n","# Перебор различных комбинаций learning_rate и epochs\n","learning_rates = [0.001, 0.01, 0.05, 0.1]\n","epochs_list = [10, 20, 30, 50]\n","\n","for lr in learning_rates:\n","    for epochs in epochs_list:\n","        perceptron = Perceptron(input_size=784, learning_rate=lr, epochs=epochs, reduce_dim=False)\n","        perceptron.fit(X_train, y_train, verbose=False)\n","\n","        # Оценка на тестовой выборке\n","        y_pred = perceptron.predict(X_test)\n","        accuracy = np.mean(y_pred == y_test)\n","\n","        if accuracy > best_accuracy_full:\n","            best_accuracy_full = accuracy\n","            best_params_full = {'lr': lr, 'epochs': epochs}\n","            best_perceptron_full = perceptron\n","\n","print(f\"\\nЛучшие параметры для полной размерности:\")\n","print(f\"  learning_rate = {best_params_full['lr']}\")\n","print(f\"  epochs = {best_params_full['epochs']}\")\n","print(f\"  Точность на тесте: {best_accuracy_full:.4f}\")\n","\n","# Обучаем лучшую модель\n","print(f\"\\nОбучение лучшей модели с параметрами: lr={best_params_full['lr']}, epochs={best_params_full['epochs']}\")\n","perceptron_full = Perceptron(input_size=784, learning_rate=best_params_full['lr'],\n","                              epochs=best_params_full['epochs'], reduce_dim=False)\n","perceptron_full.fit(X_train, y_train, verbose=True)\n","\n","# Оценка на тестовой выборке\n","y_pred_full = perceptron_full.predict(X_test)\n","test_accuracy_full = np.mean(y_pred_full == y_test)\n","print(f\"\\nТочность на тестовой выборке (полная размерность): {test_accuracy_full:.4f}\")\n","\n","print(\"\\n5. ОБУЧЕНИЕ ПЕРСЕПТРОНА (196+1 ВХОД - УМЕНЬШЕННАЯ РАЗМЕРНОСТЬ)\")\n","\n","# Сохраняем веса до обучения\n","perceptron_reduced_before = Perceptron(input_size=196, reduce_dim=True)\n","weights_before_reduced = perceptron_reduced_before.weights.copy()\n","\n","# Подбор параметров для максимального качества\n","best_accuracy_reduced = 0\n","best_params_reduced = {}\n","best_perceptron_reduced = None\n","\n","print(\"Подбор параметров обучения...\")\n","\n","for lr in learning_rates:\n","    for epochs in epochs_list:\n","        perceptron = Perceptron(input_size=196, learning_rate=lr, epochs=epochs, reduce_dim=True)\n","        perceptron.fit(X_train, y_train, verbose=False)\n","\n","        # Оценка на тестовой выборке\n","        y_pred = perceptron.predict(X_test)\n","        accuracy = np.mean(y_pred == y_test)\n","\n","        if accuracy > best_accuracy_reduced:\n","            best_accuracy_reduced = accuracy\n","            best_params_reduced = {'lr': lr, 'epochs': epochs}\n","            best_perceptron_reduced = perceptron\n","\n","print(f\"\\nЛучшие параметры для уменьшенной размерности:\")\n","print(f\"  learning_rate = {best_params_reduced['lr']}\")\n","print(f\"  epochs = {best_params_reduced['epochs']}\")\n","print(f\"  Точность на тесте: {best_accuracy_reduced:.4f}\")\n","\n","# Обучаем лучшую модель\n","print(f\"\\nОбучение лучшей модели с параметрами: lr={best_params_reduced['lr']}, epochs={best_params_reduced['epochs']}\")\n","perceptron_reduced = Perceptron(input_size=196, learning_rate=best_params_reduced['lr'],\n","                                 epochs=best_params_reduced['epochs'], reduce_dim=True)\n","perceptron_reduced.fit(X_train, y_train, verbose=True)\n","\n","# Оценка на тестовой выборке\n","y_pred_reduced = perceptron_reduced.predict(X_test)\n","test_accuracy_reduced = np.mean(y_pred_reduced == y_test)\n","print(f\"\\nТочность на тестовой выборке (уменьшенная размерность): {test_accuracy_reduced:.4f}\")\n","\n","print(\"\\n6. СРАВНЕНИЕ РЕЗУЛЬТАТОВ\")\n","print(f\"Полная размерность (784+1): точность = {test_accuracy_full:.4f}\")\n","print(f\"Уменьшенная размерность (196+1): точность = {test_accuracy_reduced:.4f}\")\n","print(f\"Разница: {abs(test_accuracy_full - test_accuracy_reduced):.4f}\")\n","\n","def plot_weights(weights_before, weights_after, title_prefix, input_size, reduce_dim=False):\n","    fig, axes = plt.subplots(2, 2, figsize=(12, 10))\n","    fig.suptitle(f'{title_prefix} - Визуализация весов', fontsize=16, fontweight='bold')\n","\n","    # Веса до обучения (без bias)\n","    if reduce_dim:\n","        weights_before_img = weights_before[:-1].reshape(14, 14)\n","        weights_after_img = weights_after[:-1].reshape(14, 14)\n","    else:\n","        weights_before_img = weights_before[:-1].reshape(28, 28)\n","        weights_after_img = weights_after[:-1].reshape(28, 28)\n","\n","    # Визуализация весов до обучения\n","    axes[0, 0].imshow(weights_before_img, cmap='RdBu', vmin=-0.1, vmax=0.1)\n","    axes[0, 0].set_title('Веса ДО обучения', fontsize=12)\n","    axes[0, 0].axis('off')\n","\n","    axes[0, 1].hist(weights_before[:-1], bins=50, color='blue', alpha=0.7)\n","    axes[0, 1].set_title('Гистограмма весов ДО обучения', fontsize=12)\n","    axes[0, 1].set_xlabel('Значение веса')\n","    axes[0, 1].set_ylabel('Частота')\n","\n","    # Визуализация весов после обучения\n","    axes[1, 0].imshow(weights_after_img, cmap='RdBu', vmin=-0.5, vmax=0.5)\n","    axes[1, 0].set_title('Веса ПОСЛЕ обучения', fontsize=12)\n","    axes[1, 0].axis('off')\n","\n","    axes[1, 1].hist(weights_after[:-1], bins=50, color='red', alpha=0.7)\n","    axes[1, 1].set_title('Гистограмма весов ПОСЛЕ обучения', fontsize=12)\n","    axes[1, 1].set_xlabel('Значение веса')\n","    axes[1, 1].set_ylabel('Частота')\n","\n","    plt.tight_layout()\n","    plt.show()\n","\n","    # Информация о bias\n","    print(f\"Bias до обучения: {weights_before[-1]:.4f}\")\n","    print(f\"Bias после обучения: {weights_after[-1]:.4f}\")\n","\n","print(\"\\n7. ВИЗУАЛИЗАЦИЯ ВЕСОВ ПЕРСЕПТРОНОВ\")\n","\n","print(\"\\n--- Полная размерность (784+1) ---\")\n","plot_weights(weights_before_full, perceptron_full.weights, \"Полная размерность\", 784, reduce_dim=False)\n","\n","print(\"\\n--- Уменьшенная размерность (196+1) ---\")\n","plot_weights(weights_before_reduced, perceptron_reduced.weights, \"Уменьшенная размерность\", 196, reduce_dim=True)\n","\n","def plot_misclassified(X_test, y_test, y_pred, title, digit1, digit2, num_examples=20):\n","    misclassified_indices = np.where(y_test != y_pred)[0]\n","\n","    if len(misclassified_indices) == 0:\n","        print(f\"Ошибок нет! Все {len(y_test)} образцов распознаны правильно.\")\n","        return\n","\n","    print(f\"Всего ошибок: {len(misclassified_indices)} из {len(y_test)} ({len(misclassified_indices)/len(y_test)*100:.2f}%)\")\n","\n","    # Показываем не более num_examples ошибок\n","    n_show = min(num_examples, len(misclassified_indices))\n","    indices_to_show = misclassified_indices[:n_show]\n","\n","    fig, axes = plt.subplots(4, 5, figsize=(15, 12))\n","    fig.suptitle(f'{title} - Ошибочно распознанные цифры', fontsize=16, fontweight='bold')\n","\n","    for i, idx in enumerate(indices_to_show):\n","        row, col = i // 5, i % 5\n","        axes[row, col].imshow(X_test[idx].reshape(28, 28), cmap='gray')\n","\n","        true_label = digit1 if y_test[idx] == 0 else digit2\n","        pred_label = digit1 if y_pred[idx] == 0 else digit2\n","\n","        axes[row, col].set_title(f'Истинная: {true_label}\\nПредсказанная: {pred_label}',\n","                                  fontsize=10, color='red')\n","        axes[row, col].axis('off')\n","\n","    # Скрыть пустые подграфики\n","    for i in range(len(indices_to_show), 20):\n","        row, col = i // 5, i % 5\n","        axes[row, col].axis('off')\n","\n","    plt.tight_layout()\n","    plt.show()\n","\n","    # Анализ ошибок\n","    print(\"\\nАнализ ошибок:\")\n","\n","    # Ошибки для цифры 1\n","    false_negatives = np.where((y_test == 0) & (y_pred == 1))[0]\n","    print(f\"  Цифра {digit1} (класс 0) распознана как {digit2}: {len(false_negatives)} ошибок\")\n","\n","    # Ошибки для цифры 2\n","    false_positives = np.where((y_test == 1) & (y_pred == 0))[0]\n","    print(f\"  Цифра {digit2} (класс 1) распознана как {digit1}: {len(false_positives)} ошибок\")\n","\n","print(\"\\n8. ВИЗУАЛИЗАЦИЯ ОШИБОЧНО РАСПОЗНАННЫХ ЦИФР\")\n","print(\"-\" * 50)\n","\n","print(\"\\n--- Полная размерность (784+1) ---\")\n","plot_misclassified(X_test, y_test, y_pred_full, \"Полная размерность\", digit1, digit2)\n","\n","print(\"\\n--- Уменьшенная размерность (196+1) ---\")\n","plot_misclassified(X_test, y_test, y_pred_reduced, \"Уменьшенная размерность\", digit1, digit2)\n","\n","def analyze_misclassified_samples(X_test, y_test, y_pred, digit1, digit2):\n","    misclassified = np.where(y_test != y_pred)[0]\n","\n","    if len(misclassified) == 0:\n","        return\n","\n","    print(\"\\nДетальный анализ ошибок:\")\n","\n","    for idx in misclassified[:10]:  # Анализируем первые 10 ошибок\n","        true_class = digit1 if y_test[idx] == 0 else digit2\n","        pred_class = digit1 if y_pred[idx] == 0 else digit2\n","\n","        img = X_test[idx].reshape(28, 28)\n","\n","        # Статистика по изображению\n","        mean_intensity = np.mean(img)\n","        std_intensity = np.std(img)\n","\n","        print(f\"\\nОбразец #{idx}:\")\n","        print(f\"  Истинная цифра: {true_class}, Предсказанная: {pred_class}\")\n","        print(f\"  Средняя интенсивность: {mean_intensity:.3f}\")\n","        print(f\"  Стандартное отклонение: {std_intensity:.3f}\")\n","\n","        # Визуализация отдельно для каждого ошибочного образца\n","        fig, ax = plt.subplots(1, 1, figsize=(3, 3))\n","        ax.imshow(img, cmap='gray')\n","        ax.set_title(f'Истинная: {true_class} -> Предсказанная: {pred_class}',\n","                     fontsize=10, color='red')\n","        ax.axis('off')\n","        plt.show()\n","\n","print(\"\\n9. АНАЛИЗ ОШИБОК РАСПОЗНАВАНИЯ\")\n","print(\"-\" * 50)\n","\n","print(\"\\n--- Анализ для полной размерности ---\")\n","analyze_misclassified_samples(X_test, y_test, y_pred_full, digit1, digit2)\n","\n","print(\"\\n--- Анализ для уменьшенной размерности ---\")\n","analyze_misclassified_samples(X_test, y_test, y_pred_reduced, digit1, digit2)\n","\n","# ====================== 12. ГРАФИКИ ОБУЧЕНИЯ ======================\n","def plot_training_history(perceptron_full, perceptron_reduced):\n","    \"\"\"Визуализация истории обучения\"\"\"\n","    fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n","    fig.suptitle('История обучения персептронов', fontsize=16, fontweight='bold')\n","\n","    # Точность для полной размерности\n","    epochs_full = range(1, len(perceptron_full.accuracy_history) + 1)\n","    axes[0, 0].plot(epochs_full, perceptron_full.accuracy_history, 'b-', linewidth=2)\n","    axes[0, 0].set_title('Полная размерность (784+1) - Точность', fontsize=12)\n","    axes[0, 0].set_xlabel('Эпоха')\n","    axes[0, 0].set_ylabel('Точность')\n","    axes[0, 0].grid(True, alpha=0.3)\n","    axes[0, 0].set_ylim([0, 1.05])\n","\n","    # Количество ошибок для полной размерности\n","    axes[1, 0].plot(epochs_full, perceptron_full.loss_history, 'r-', linewidth=2)\n","    axes[1, 0].set_title('Полная размерность